---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'Hongjun Qiu — Product Manager',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'View Projects',
        href: '/projects',
        icon: 'tabler:briefcase',
      },
      { 
        text: 'Read Blog', 
        href: '/blog',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Hi, I'm <span class="text-accent dark:text-white">Hongjun</span> 👋
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Product Manager</span> based in Shanghai.<br class="hidden sm:inline" />
      I build products that matter. Interested in AI, fintech, and understanding where the world is heading.<br class="hidden sm:inline" />
      Currently exploring the intersection of <span class="font-semibold">AI agents</span> and everyday life.
    </Fragment>
  </Hero>

  <!-- Interests Section -->
  <Features
    id="interests"
    tagline="What I Care About"
    title="Areas of Focus"
    subtitle="Things I spend my time thinking about and building."
    items={[
      {
        title: 'AI & Agents',
        description: 'Exploring how AI agents can augment human capabilities and automate the mundane.',
        icon: 'tabler:robot',
      },
      {
        title: 'Product Strategy',
        description: 'Turning ambiguity into clarity. Finding the right problems to solve.',
        icon: 'tabler:target',
      },
      {
        title: 'Fintech & Investing',
        description: 'Understanding markets, building wealth, making sense of economic trends.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Technology Trends',
        description: 'Staying curious about what\'s next. From infra to consumer tech.',
        icon: 'tabler:trending-up',
      },
    ]}
  />

  <!-- Latest Posts -->
  <BlogLatestPosts
    title="Latest from the Blog"
    information="Thoughts on product, tech, and life."
  />
</Layout>
