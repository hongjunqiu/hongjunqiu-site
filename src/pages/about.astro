---
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    tagline="About Me"
  >
    <Fragment slot="title">
      Hongjun Qiu
    </Fragment>

    <Fragment slot="subtitle">
      Product Manager based in Shanghai. I enjoy building things, understanding systems, and figuring out where the world is heading.<br /><br />
      
      By day, I work on products in the tech industry. By night, I tinker with AI agents, track markets, and occasionally write about what I learn.<br /><br />
      
      I believe in <span class="font-semibold">learning by doing</span>, <span class="font-semibold">staying curious</span>, and <span class="font-semibold">not taking things too seriously</span>. 
      Life's too short for boring products and lengthy meetings.
    </Fragment>
  </Hero>

  <!-- Background -->
  <Steps2
    title="Background"
    subtitle="A few things about my journey."
    items={[
      {
        title: 'Product Management',
        description: 'Years of experience turning ideas into products. From 0-to-1 builds to scaling existing features.',
      },
      {
        title: 'Tech Enthusiast',
        description: 'Always exploring new technologies. Currently deep in the AI agent rabbit hole with OpenClaw.',
      },
      {
        title: 'Investor Mindset',
        description: 'Interested in markets, macro trends, and building long-term wealth. Track tech stocks, gold, and silver.',
      },
    ]}
  />

  <!-- Interests -->
  <Features
    title="Current Interests"
    subtitle="What's on my mind these days."
    items={[
      {
        title: 'AI Agents',
        description: 'Building personal AI assistants that actually help with daily life, not just chat.',
        icon: 'tabler:robot',
      },
      {
        title: 'Reading',
        description: 'Non-fiction mostly. Business, technology, psychology, and the occasional sci-fi.',
        icon: 'tabler:book',
      },
      {
        title: 'Markets & Investing',
        description: 'Understanding economic cycles, tracking tech stocks, and learning to be patient.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Building in Public',
        description: 'Sharing what I learn through this blog and side projects.',
        icon: 'tabler:pencil',
      },
    ]}
  />
</Layout>
