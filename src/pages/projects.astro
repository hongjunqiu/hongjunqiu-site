---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Projects',
};

const projects = [
  {
    title: 'OpenClaw',
    description: 'Personal AI assistant that connects to messaging apps, manages schedules, and automates daily tasks. My daily driver for exploring AI agent capabilities.',
    icon: 'tabler:robot',
  },
  {
    title: 'Investment Dashboard',
    description: 'Automated daily market reports covering tech stocks, gold, and silver. Delivered to messaging apps every morning.',
    icon: 'tabler:chart-candle',
  },
  {
    title: 'More Coming Soon',
    description: 'Always building, always learning. Check back for updates or follow my blog.',
    icon: 'tabler:dots',
  },
];
---

<Layout metadata={metadata}>
  <Hero
    tagline="Projects"
  >
    <Fragment slot="title">
      Things I've Built
    </Fragment>
    <Fragment slot="subtitle">
      Side projects, experiments, and tools I use daily.
    </Fragment>
  </Hero>

  <Features2
    items={projects}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>
</Layout>
