---
export interface Props {
  src: string;
}
const { src } = Astro.props;
---
<div class="podcast-player" data-audio-src={src}>
  <div class="player-container" style="background: linear-gradient(135deg, #eef2ff 0%, #f8fafc 100%); border-radius: 16px; padding: 20px; margin: 1.5rem 0; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div class="waveform-container" style="margin-bottom: 12px;"></div>
    <div style="display: flex; align-items: center; gap: 12px;">
      <button class="play-btn" style="background: #6366f1; color: white; border: none; border-radius: 50%; width: 44px; height: 44px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: background 0.2s; flex-shrink: 0;" aria-label="Play">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </button>
      <span class="current-time" style="font-variant-numeric: tabular-nums; color: #6b7280; font-size: 0.875rem; min-width: 36px;">0:00</span>
      <span style="color: #d1d5db;">/</span>
      <span class="duration" style="font-variant-numeric: tabular-nums; color: #6b7280; font-size: 0.875rem; min-width: 36px;">0:00</span>
      <div style="margin-left: auto; display: flex; gap: 4px;">
        <button class="speed-btn" data-speed="0.5" style="background: transparent; border: 1px solid #e5e7eb; border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: #6b7280; cursor: pointer; transition: all 0.2s;">0.5x</button>
        <button class="speed-btn active" data-speed="1" style="background: #6366f1; border: 1px solid #6366f1; border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: white; cursor: pointer; transition: all 0.2s;">1x</button>
        <button class="speed-btn" data-speed="1.5" style="background: transparent; border: 1px solid #e5e7eb; border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: #6b7280; cursor: pointer; transition: all 0.2s;">1.5x</button>
        <button class="speed-btn" data-speed="2" style="background: transparent; border: 1px solid #e5e7eb; border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: #6b7280; cursor: pointer; transition: all 0.2s;">2x</button>
      </div>
    </div>
  </div>
</div>

<script>
  import WaveSurfer from 'wavesurfer.js';

  function initPlayers() {
    document.querySelectorAll('.podcast-player').forEach((container) => {
      if ((container as HTMLElement).dataset.initialized) return;
      (container as HTMLElement).dataset.initialized = 'true';

      const audioSrc = (container as HTMLElement).dataset.audioSrc;
      const waveformEl = container.querySelector('.waveform-container') as HTMLElement;

      const ws = WaveSurfer.create({
        container: waveformEl,
        waveColor: '#a5b4fc',
        progressColor: '#6366f1',
        cursorColor: '#4f46e5',
        barWidth: 3,
        barRadius: 3,
        barGap: 2,
        height: 64,
        normalize: true,
        url: audioSrc!,
      });

      const playBtn = container.querySelector('.play-btn') as HTMLElement;
      const currentTimeEl = container.querySelector('.current-time') as HTMLElement;
      const durationEl = container.querySelector('.duration') as HTMLElement;
      const speedBtns = container.querySelectorAll('.speed-btn');

      const playSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
      const pauseSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';

      function formatTime(s: number) {
        const m = Math.floor(s / 60);
        return m + ':' + String(Math.floor(s % 60)).padStart(2, '0');
      }

      playBtn.addEventListener('click', () => ws.playPause());
      ws.on('play', () => { playBtn.innerHTML = pauseSvg; });
      ws.on('pause', () => { playBtn.innerHTML = playSvg; });
      ws.on('timeupdate', (t: number) => { currentTimeEl.textContent = formatTime(t); });
      ws.on('ready', () => { durationEl.textContent = formatTime(ws.getDuration()); });

      speedBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          speedBtns.forEach(b => {
            (b as HTMLElement).style.background = 'transparent';
            (b as HTMLElement).style.borderColor = '#e5e7eb';
            (b as HTMLElement).style.color = '#6b7280';
          });
          (btn as HTMLElement).style.background = '#6366f1';
          (btn as HTMLElement).style.borderColor = '#6366f1';
          (btn as HTMLElement).style.color = 'white';
          ws.setPlaybackRate(parseFloat((btn as HTMLElement).dataset.speed!));
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initPlayers);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayers);
  } else {
    initPlayers();
  }
</script>
