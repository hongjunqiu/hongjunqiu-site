---
export interface Props {
  src: string;
  title?: string;
  date?: string;
}
const { src, title, date } = Astro.props;
---
<div class="podcast-player" data-audio-src={src} data-title={title} data-date={date}>
  <div class="player-container" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: 16px; padding: 20px; margin: 1.5rem 0; box-shadow: 0 4px 24px rgba(0,0,0,0.3);">
    {(title || date) && (
      <div style="color: rgba(255,255,255,0.7); font-size: 0.8rem; margin-bottom: 10px; letter-spacing: 0.02em;">
        🎙️ {title || '科技早知道'}{date ? ` · ${date}` : ''}
      </div>
    )}
    <div class="waveform-container" style="margin-bottom: 12px;"></div>
    <div style="display: flex; align-items: center; gap: 12px;">
      <button class="play-btn" style="background: rgba(255,255,255,0.15); color: white; border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; width: 44px; height: 44px; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; flex-shrink: 0;" aria-label="Play">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </button>
      <span class="current-time" style="font-variant-numeric: tabular-nums; color: rgba(255,255,255,0.8); font-size: 0.875rem; min-width: 36px;">0:00</span>
      <span style="color: rgba(255,255,255,0.4);">/</span>
      <span class="duration" style="font-variant-numeric: tabular-nums; color: rgba(255,255,255,0.8); font-size: 0.875rem; min-width: 36px;">0:00</span>
      <div style="margin-left: auto; display: flex; gap: 4px;">
        <button class="speed-btn" data-speed="0.5" style="background: transparent; border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: rgba(255,255,255,0.6); cursor: pointer; transition: all 0.2s;">0.5x</button>
        <button class="speed-btn active" data-speed="1" style="background: rgba(255,255,255,0.9); border: 1px solid rgba(255,255,255,0.9); border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: #1a1a2e; cursor: pointer; transition: all 0.2s;">1x</button>
        <button class="speed-btn" data-speed="1.5" style="background: transparent; border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: rgba(255,255,255,0.6); cursor: pointer; transition: all 0.2s;">1.5x</button>
        <button class="speed-btn" data-speed="2" style="background: transparent; border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; padding: 4px 8px; font-size: 0.75rem; color: rgba(255,255,255,0.6); cursor: pointer; transition: all 0.2s;">2x</button>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(139, 92, 246, 0); }
  }
  .play-btn.playing {
    animation: pulse-glow 2s ease-in-out infinite;
    background: rgba(139, 92, 246, 0.4) !important;
    border-color: rgba(139, 92, 246, 0.6) !important;
  }
</style>

<script>
  import WaveSurfer from 'wavesurfer.js';

  function initPlayers() {
    document.querySelectorAll('.podcast-player').forEach((container) => {
      if ((container as HTMLElement).dataset.initialized) return;
      (container as HTMLElement).dataset.initialized = 'true';

      const audioSrc = (container as HTMLElement).dataset.audioSrc;
      const waveformEl = container.querySelector('.waveform-container') as HTMLElement;

      const ws = WaveSurfer.create({
        container: waveformEl,
        waveColor: ['rgba(139, 92, 246, 0.6)', 'rgba(59, 130, 246, 0.6)', 'rgba(16, 185, 129, 0.4)'],
        progressColor: ['#8B5CF6', '#3B82F6', '#10B981'],
        cursorColor: '#FFFFFF',
        barWidth: 3,
        barRadius: 3,
        barGap: 2,
        barMinHeight: 2,
        height: 64,
        normalize: true,
        dragToSeek: true,
        url: audioSrc!,
      });

      const playBtn = container.querySelector('.play-btn') as HTMLElement;
      const currentTimeEl = container.querySelector('.current-time') as HTMLElement;
      const durationEl = container.querySelector('.duration') as HTMLElement;
      const speedBtns = container.querySelectorAll('.speed-btn');

      const playSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>';
      const pauseSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>';

      function formatTime(s: number) {
        const m = Math.floor(s / 60);
        return m + ':' + String(Math.floor(s % 60)).padStart(2, '0');
      }

      playBtn.addEventListener('click', () => ws.playPause());
      ws.on('play', () => { playBtn.innerHTML = pauseSvg; playBtn.classList.add('playing'); });
      ws.on('pause', () => { playBtn.innerHTML = playSvg; playBtn.classList.remove('playing'); });
      ws.on('timeupdate', (t: number) => { currentTimeEl.textContent = formatTime(t); });
      ws.on('ready', () => { durationEl.textContent = formatTime(ws.getDuration()); });

      speedBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          speedBtns.forEach(b => {
            (b as HTMLElement).style.background = 'transparent';
            (b as HTMLElement).style.borderColor = 'rgba(255,255,255,0.2)';
            (b as HTMLElement).style.color = 'rgba(255,255,255,0.6)';
          });
          (btn as HTMLElement).style.background = 'rgba(255,255,255,0.9)';
          (btn as HTMLElement).style.borderColor = 'rgba(255,255,255,0.9)';
          (btn as HTMLElement).style.color = '#1a1a2e';
          ws.setPlaybackRate(parseFloat((btn as HTMLElement).dataset.speed!));
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initPlayers);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayers);
  } else {
    initPlayers();
  }
</script>
